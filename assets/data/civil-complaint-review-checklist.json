{
  "version": 1,
  "title": "民事起诉状审查要点",
  "legal_basis": [
    {
      "id": "qc-law-1",
      "text": "《中华人民共和国民事诉讼法》第一百二十二条（起诉条件）"
    },
    {
      "id": "qc-law-2",
      "text": "《中华人民共和国民事诉讼法》第一百二十四条（起诉状应记明事项）"
    }
  ],
  "sections": [
    {
      "id": "qc-s01",
      "title": "一、当事人与诉讼主体",
      "items": [
        {
          "id": "qc-s01-01",
          "text": "是否写明原告姓名/名称、性别、住所、身份证明或统一社会信用代码等基本信息（自然人、法人或其他组织对应信息是否齐全）"
        },
        {
          "id": "qc-s01-02",
          "text": "是否写明被告姓名/名称、住所等足以与他人相区别的信息（被告明确、可特定）"
        },
        {
          "id": "qc-s01-03",
          "text": "是否存在共同诉讼：必要共同诉讼的共同原告/被告是否列明；普通共同诉讼是否可合并需在理由中说明"
        },
        {
          "id": "qc-s01-04",
          "text": "无/限制民事行为能力人是否列明法定代理人及与原告关系"
        },
        {
          "id": "qc-s01-05",
          "text": "是否委托诉讼代理人：姓名、单位、职务及权限（一般授权/特别授权）是否写明"
        },
        {
          "id": "qc-s01-06",
          "text": "第三人（有独立请求权或无独立请求权）是否应参加诉讼：若需列明第三人，是否写明"
        }
      ]
    },
    {
      "id": "qc-s02",
      "title": "二、诉讼请求",
      "items": [
        {
          "id": "qc-s02-01",
          "text": "诉讼请求是否具体、明确，具有可执行性或可裁判性（避免笼统表述）"
        },
        {
          "id": "qc-s02-02",
          "text": "给付之诉：是否写明给付标的、种类、数额或计算方法（如本金、利息、违约金、起止时间）"
        },
        {
          "id": "qc-s02-03",
          "text": "确认之诉/形成之诉：请求确认或变更的法律关系是否表述清楚"
        },
        {
          "id": "qc-s02-04",
          "text": "多项诉讼请求之间是否存在矛盾或竞合，需否拆分或择一"
        },
        {
          "id": "qc-s02-05",
          "text": "是否写明请求被告承担诉讼费用（及是否请求保全费、鉴定费等可单列费用）"
        },
        {
          "id": "qc-s02-06",
          "text": "是否提示需申请保全、先予执行等：若已申请，是否与正文一致"
        }
      ]
    },
    {
      "id": "qc-s03",
      "title": "三、事实与理由",
      "items": [
        {
          "id": "qc-s03-01",
          "text": "事实是否按时间顺序或逻辑顺序叙述，主线是否清楚"
        },
        {
          "id": "qc-s03-02",
          "text": "是否写明合同订立、履行、违约或侵权等关键节点及因果关系"
        },
        {
          "id": "qc-s03-03",
          "text": "是否区分客观事实与法律评价，避免仅以结论代替事实"
        },
        {
          "id": "qc-s03-04",
          "text": "是否概括并引用拟支持请求的主要法律依据（法律名称及条款可指向）"
        },
        {
          "id": "qc-s03-05",
          "text": "是否说明与被告协商、催告、前置程序（如仲裁、行政处理）经过（如案情需要）"
        },
        {
          "id": "qc-s03-06",
          "text": "理由部分是否回应诉讼请求，论证是否覆盖各请求权基础"
        }
      ]
    },
    {
      "id": "qc-s04",
      "title": "四、证据与举证",
      "items": [
        {
          "id": "qc-s04-01",
          "text": "是否附证据目录或列举证据名称、来源、证明目的"
        },
        {
          "id": "qc-s04-02",
          "text": "证据与待证事实之间对应关系是否清楚"
        },
        {
          "id": "qc-s04-03",
          "text": "电子数据、视听资料等是否说明来源与形式（如需要）"
        },
        {
          "id": "qc-s04-04",
          "text": "是否申请证人出庭：若需，是否列明证人姓名及拟证明事实"
        },
        {
          "id": "qc-s04-05",
          "text": "是否说明举证责任分配或对方持有证据的申请（如适用）"
        }
      ]
    },
    {
      "id": "qc-s05",
      "title": "五、管辖与程序",
      "items": [
        {
          "id": "qc-s05-01",
          "text": "是否写明致送人民法院的全称，与级别管辖、专门管辖是否匹配"
        },
        {
          "id": "qc-s05-02",
          "text": "地域管辖依据是否说明（被告住所地、合同履行地、侵权行为地、协议管辖等）"
        },
        {
          "id": "qc-s05-03",
          "text": "劳动争议等依法须仲裁前置的：是否说明已仲裁或一并说明仲裁情况"
        },
        {
          "id": "qc-s05-04",
          "text": "是否涉及诉讼时效：文书中是否提示或说明起算、中断事由（如适用）"
        },
        {
          "id": "qc-s05-05",
          "text": "是否属于重复起诉、裁定已生效等情形需在理由中排除（如适用）"
        }
      ]
    },
    {
      "id": "qc-s06",
      "title": "六、文书形式与结尾",
      "items": [
        {
          "id": "qc-s06-01",
          "text": "是否写明“此致”“××人民法院”及具状人签章位置"
        },
        {
          "id": "qc-s06-02",
          "text": "是否写明起诉日期"
        },
        {
          "id": "qc-s06-03",
          "text": "是否写明副本份数（按被告人数+N）及提交材料说明（如法院另有要求）"
        },
        {
          "id": "qc-s06-04",
          "text": "是否注明送达地址、联系电话、电子邮箱（送达地址确认书相关，如法院要求）"
        },
        {
          "id": "qc-s06-05",
          "text": "法人起诉是否需法定代表人/负责人签名或盖章：形式是否完整"
        }
      ]
    }
  ]
}
